{
  "name": "Roland Tone Library PoC - Java + Node",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21",
      "installMaven": true
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "postCreateCommand": "echo 'Environment ready for Spring Boot + Next.js PoC. Run: cd backend && ./mvnw spring-boot:run  |  cd frontend && npm install && npm run dev'",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "forwardPorts": [8080, 3000],
  "portsAttributes": {
    "8080": {
      "label": "Spring Boot Backend (http://localhost:8080)",
      "onAutoForward": "notify"
    },
    "3000": {
      "label": "Next.js Frontend (http://localhost:3000)",
      "onAutoForward": "notify"
    }
  }
}