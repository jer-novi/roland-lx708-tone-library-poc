# Render Blueprint: maakt de backend-service aan met de juiste instellingen.
# Gebruik: Render dashboard -> New -> Blueprint -> kies deze repo.
# De drie env vars met "sync: false" vul je eenmalig in het dashboard in.
services:
  - type: web
    name: roland-tone-library-api
    runtime: docker
    repo: https://github.com/jer-novi/roland-lx708-tone-library-poc
    rootDir: backend
    dockerfilePath: ./Dockerfile
    region: frankfurt
    plan: free
    healthCheckPath: /actuator/health
    envVars:
      # Vul deze drie eenmalig in het Render-dashboard in (nooit in de repo).
      - key: DB_URL
        sync: false
      - key: DB_USERNAME
        sync: false
      - key: DB_PASSWORD
        sync: false
      - key: CORS_ALLOWED_ORIGINS
        value: https://roland-lx708-tone-library-poc.vercel.app,https://roland-lx708-tone-library-poc-git-main-jer-novis-projects.vercel.app,http://localhost:3000,http://localhost:3001,
      - key: SEED_ENABLED
        value: "true"
